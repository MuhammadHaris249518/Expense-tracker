# 🔐 Environment Configuration Template
# Copy this to .env and fill with your actual values
# NEVER commit .env to git!

# ============================================
# BACKEND (Node.js Express) Configuration
# ============================================

# MongoDB Configuration (shared with Python)
MONGODB_URI=mongodb://localhost:27017/ExpenseTrackerDB

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here_min_32_chars

# Server Configuration
PORT=3000
NODE_ENV=development
ORIGIN=http://localhost:5173

# AI Service (Python FastAPI) Configuration
AI_SERVICE_URL=http://localhost:8000

# ============================================
# PYTHON (FastAPI) Configuration
# ============================================

# Database Configuration (async MongoDB)
DATABASE_URL=mongodb://localhost:27017

# Email Configuration (Gmail)
# EMAIL_USER: Gmail account that sends the emails
# EMAIL_PASSWORD: Gmail app-specific password (not regular password)
# EMAIL_FROM: The sender email address (use harrylife581@gmail.com for production)
EMAIL_USER=harrylife581@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
EMAIL_FROM=harrylife581@gmail.com

# Google Gemini API Configuration
# GEMINI_API_KEY: Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Daily Report Configuration
DAILY_REPORT_TIME=18:00

# ============================================
# FRONTEND (React/Vite) Configuration
# ============================================
# Note: Frontend env vars are in src/frontend/.env
VITE_API_BASE_URL=http://localhost:3000
