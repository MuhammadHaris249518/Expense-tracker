# 🔐 Backend Server Environment Configuration
# Copy this to .env and fill with your actual values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/MyNewDatabase

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here_min_32_chars

# Server Configuration
PORT=3000
NODE_ENV=development
ORIGIN=http://localhost:5173

# AI Service (Python FastAPI) Configuration
AI_SERVICE_URL=http://localhost:8000
